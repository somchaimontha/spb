# Git ignore rules for ระบบงานแผนและงบประมาณ
# Prevent sensitive files and configuration from being committed

# System files
.DS_Store
.env
.env.local
.env.*.local
Thumbs.db

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*.code-workspace

# Sensitive Configuration Files
config.js
config.local.js
.apikey
api.key

# Google Apps Script — จัดการผ่าน script.google.com โดยตรง ไม่ต้อง push
gas/
Code.gs
appsscript.json
databasesetup.gs
*.clasp.json

# Environment & Credentials
.credentials
.auth
credentials.json
token.json

# Data & Database (อนาคต)
rdfdatasheet/
data/
*.db
*.sqlite

# Documentation & Markdown files (ส่วนตัว — ไม่ push ไป GitHub)
docs/
AGENTS.md
GIT_SECURITY.md
GUIDE.md
IMPLEMENTATION.md
PROJECT_STATUS.md
data_structure_mapping.md
planwork_webapp_prompt.md
PRIVATE_NOTES.md
TODO.md
TEMP/
*.md

# Node modules (ถ้ามีการใช้ npm ในอนาคต)
node_modules/
package-lock.json
yarn.lock

# Build outputs
dist/
build/
*.min.js
*.min.css

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*

# Uploads — ข้อมูลงบประมาณจริง ห้าม push เด็ดขาด
uploads/
planwork_webapp_prompt.md

# Next phase backend (when added)
backend/
.netlify/
/functions/

# OS specific
.AppleDouble
.LSOverride
._*

# IDE plugins
.elixir_ls/
.vimrc

# Test coverage
coverage/
.nyc_output/

# Backup files
*.backup
*.bak
*~
*.tmp

# Private keys & Certificates
*.pem
*.key
*.cert
